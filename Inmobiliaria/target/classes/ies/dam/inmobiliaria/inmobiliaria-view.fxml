<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ies.dam.inmobiliaria.controller.InmobiliariaController"
            prefHeight="560.0"
            prefWidth="950.0"
            styleClass="root">

    <top>
        <VBox spacing="10" styleClass="cabecera">
            <padding>
                <Insets top="20" right="20" bottom="15" left="20"/>
            </padding>

            <Label text="Consulta de viviendas disponibles" styleClass="titulo"/>
            <Label text="Selecciona si quieres comprar o alquilar una vivienda y consulta las opciones disponibles."
                   styleClass="subtitulo"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="15">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <HBox spacing="12" styleClass="panel-busqueda">
                <Label text="Tipo de operación:" styleClass="etiqueta"/>

                <ComboBox fx:id="cmbTipoOperacion"
                          id="cmbTipoOperacion"
                          prefWidth="220"/>

                <Button fx:id="btnBuscar"
                        id="btnBuscar"
                        text="Buscar viviendas"
                        onAction="#buscarViviendas"
                        styleClass="boton-principal"/>

                <Button fx:id="btnLimpiar"
                        id="btnLimpiar"
                        text="Limpiar"
                        onAction="#limpiarBusqueda"
                        styleClass="boton-secundario"/>
            </HBox>

            <Label fx:id="lblResultado"
                   id="lblResultado"
                   text="Selecciona compra o alquiler para filtrar las viviendas disponibles."
                   styleClass="mensaje-info"/>

            <TableView fx:id="tablaViviendas"
                       id="tablaViviendas"
                       VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="45"/>
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="95"/>
                    <TableColumn fx:id="colDireccion" text="Dirección" prefWidth="250"/>
                    <TableColumn fx:id="colCiudad" text="Ciudad" prefWidth="120"/>
                    <TableColumn fx:id="colHabitaciones" text="Hab." prefWidth="70"/>
                    <TableColumn fx:id="colMetros" text="m²" prefWidth="80"/>
                    <TableColumn fx:id="colPrecio" text="Precio" prefWidth="120"/>
                    <TableColumn fx:id="colDisponibilidad" text="Estado" prefWidth="130"/>
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>
